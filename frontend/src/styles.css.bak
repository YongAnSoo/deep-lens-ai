* { box-sizing: border-box; }
body { margin: 0; font-family: Arial, "Microsoft YaHei", sans-serif; background: #0f172a; color: #e5e7eb; }
a { color: inherit; text-decoration: none; }
.app-shell { min-height: 100vh; }
.navbar { height: 72px; padding: 0 42px; border-bottom: 1px solid #1e293b; background: rgba(15,23,42,.93); display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 20; backdrop-filter: blur(12px); }
.brand { display: flex; align-items: center; gap: 12px; font-size: 18px; font-weight: 900; }
.brand-mark { width: 36px; height: 36px; display: inline-flex; align-items: center; justify-content: center; border-radius: 12px; background: linear-gradient(135deg, #2563eb, #38bdf8); color: white; font-size: 13px; }
.nav-links { display: flex; gap: 18px; color: #cbd5e1; }
.nav-links a { padding: 9px 12px; border-radius: 12px; }
.nav-links a.active, .nav-links a:hover { background: #1e293b; color: #fff; }
.main-content { max-width: 1160px; margin: 0 auto; padding: 52px 24px; }
.hero-grid { display: grid; grid-template-columns: 1.05fr .95fr; gap: 34px; align-items: center; }
.eyebrow { color: #38bdf8; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
h1 { font-size: 48px; line-height: 1.12; margin: 12px 0; }
h2 { margin-top: 0; }
.subtitle { color: #cbd5e1; font-size: 18px; line-height: 1.75; }
.button-row { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 24px; }
.primary-button, .secondary-button { border: none; display: inline-flex; align-items: center; justify-content: center; border-radius: 14px; padding: 14px 20px; font-weight: 900; cursor: pointer; }
.primary-button { background: #2563eb; color: white; }
.primary-button:disabled { background: #475569; cursor: not-allowed; }
.secondary-button { background: #1e293b; border: 1px solid #334155; color: #e5e7eb; }
.card, .feature-card { background: #111827; border: 1px solid #334155; border-radius: 22px; padding: 26px; box-shadow: 0 20px 42px rgba(0,0,0,.28); }
.feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
.feature-card p, .hint { color: #94a3b8; line-height: 1.65; }
.page-header { margin-bottom: 28px; }
.upload-card { max-width: 780px; }
.file-input { display: block; width: 100%; padding: 16px; margin: 18px 0; border: 1px dashed #64748b; border-radius: 14px; background: #020617; color: #e5e7eb; }
.selected-file { color: #bae6fd; }
.error-text { color: #fca5a5; }
.result-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
.result-grid > div { background: #020617; border-radius: 16px; padding: 18px; }
.label { color: #94a3b8; margin: 0 0 8px; }
.score { font-size: 22px; font-weight: 900; margin: 0; }
.small-score { font-size: 16px; word-break: break-word; }
.fake-label { color: #f87171; font-size: 22px; font-weight: 900; margin: 0; }
.real-label { color: #4ade80; font-size: 22px; font-weight: 900; margin: 0; }
.explanation-box { margin-top: 24px; background: #020617; border-radius: 18px; padding: 22px; line-height: 1.75; white-space: pre-wrap; }
.explain-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
.placeholder-box { height: 260px; border-radius: 18px; border: 1px dashed #475569; background: #020617; color: #64748b; display: flex; align-items: center; justify-content: center; }
.gradcam-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
.gradcam-card { background: #020617; border-radius: 16px; padding: 12px; }
.gradcam-card img { width: 100%; border-radius: 12px; display: block; }
.metric-list p { display: flex; justify-content: space-between; gap: 14px; padding: 12px 0; border-bottom: 1px solid #1e293b; }
.metric-list span { color: #94a3b8; }
.metric-list b { text-align: right; word-break: break-word; }
.llm-text { line-height: 1.8; white-space: pre-wrap; color: #e2e8f0; }
@media (max-width: 900px) { .navbar { height: auto; flex-direction: column; padding: 18px 22px; gap: 14px; } .nav-links { flex-wrap: wrap; justify-content: center; } .hero-grid, .feature-grid, .result-grid, .explain-grid, .gradcam-grid { grid-template-columns: 1fr; } h1 { font-size: 36px; } }
